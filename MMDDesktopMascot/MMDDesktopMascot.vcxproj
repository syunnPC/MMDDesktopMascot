  <Target Name="EnsureBulletLibraries" BeforeTargets="Link">
    <PropertyGroup>
      <RepoRoot>$(MSBuildProjectDirectory)\..</RepoRoot>
      <BulletSourceDir>$(RepoRoot)\external\bullet3</BulletSourceDir>
      <BulletBuildDir>$(RepoRoot)\build\bullet-msbuild</BulletBuildDir>
      <BulletLibDir>$(BulletBuildDir)\lib\$(Configuration)</BulletLibDir>
      <BulletSoftBodyLib>$(BulletLibDir)\BulletSoftBody$(BulletLibrarySuffix).lib</BulletSoftBodyLib>
      <BulletDynamicsLib>$(BulletLibDir)\BulletDynamics$(BulletLibrarySuffix).lib</BulletDynamicsLib>
      <BulletCollisionLib>$(BulletLibDir)\BulletCollision$(BulletLibrarySuffix).lib</BulletCollisionLib>
      <LinearMathLib>$(BulletLibDir)\LinearMath$(BulletLibrarySuffix).lib</LinearMathLib>
      <BulletProvisionStamp>$(BulletBuildDir)\.copilot-bullet-runtime-md-v1.stamp</BulletProvisionStamp>
      <BulletNeedsProvision>false</BulletNeedsProvision>
      <BulletNeedsProvision Condition="!Exists('$(BulletBuildDir)\CMakeCache.txt') OR !Exists('$(BulletSoftBodyLib)') OR !Exists('$(BulletDynamicsLib)') OR !Exists('$(BulletCollisionLib)') OR !Exists('$(LinearMathLib)') OR !Exists('$(BulletProvisionStamp)')">true</BulletNeedsProvision>
    </PropertyGroup>
    <Message Importance="high" Text="Provisioning Bullet dependency artifacts in $(BulletBuildDir)..." Condition="'$(BulletNeedsProvision)'=='true'" />
    <Exec Command="cmake -S &quot;$(BulletSourceDir)&quot; -B &quot;$(BulletBuildDir)&quot; -G &quot;Visual Studio 17 2022&quot; -A x64 -T $(PlatformToolset) -DCMAKE_POLICY_VERSION_MINIMUM=3.5 -DUSE_MSVC_RUNTIME_LIBRARY_DLL=ON -DBUILD_BULLET2_DEMOS=OFF -DBUILD_CPU_DEMOS=OFF -DBUILD_OPENGL3_DEMOS=OFF -DBUILD_UNIT_TESTS=OFF -DBUILD_EXTRAS=OFF -DBUILD_BULLET3=OFF -DBUILD_PYBULLET=OFF -DBUILD_ENET=OFF -DBUILD_CLSOCKET=OFF -DUSE_GRAPHICAL_BENCHMARK=OFF -DINSTALL_LIBS=OFF" Condition="'$(BulletNeedsProvision)'=='true'" />
    <Exec Command="cmake --build &quot;$(BulletBuildDir)&quot; --config $(Configuration) --target BulletSoftBody BulletDynamics BulletCollision LinearMath" Condition="'$(BulletNeedsProvision)'=='true'" />
    <WriteLinesToFile File="$(BulletProvisionStamp)" Lines="USE_MSVC_RUNTIME_LIBRARY_DLL=ON" Overwrite="true" Condition="'$(BulletNeedsProvision)'=='true'" />
  </Target>
  <Target Name="CopyRuntimeShaders" AfterTargets="Build">
    <ItemGroup>
